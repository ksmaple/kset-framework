# KSet 本地部署环境变量（统一模板）
# 复制为 config/.env 后修改；启动脚本会自动同步到 env/.env

COMPOSE_PROJECT_NAME=kset-framework

# Nacos
NACOS_IMAGE=nacos/nacos-server:v2.3.2
NACOS_HTTP_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_RAFT_PORT=9849

# PostgreSQL（可选，demo 默认用 SQLite）
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_PORT=5432
POSTGRES_DB=kset_demo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
REDIS_IMAGE=redis:7.2-alpine
REDIS_PORT=6379

# CAT
CAT_HTTP_PORT=8088
CAT_TCP_PORT=2280
CAT_MYSQL_PORT=3307
CAT_MYSQL_IMAGE=mysql:5.7.37
