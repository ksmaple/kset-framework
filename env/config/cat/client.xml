<?xml version="1.0" encoding="utf-8"?>
<!--
  CAT 客户端连接配置（配置源）。
  启动 env/up 时会自动复制到：
  - env/cat/appdatas/client.xml（CAT 容器）
  - kset-demo/env/cat/client.xml（Spring 应用）
  - data/appdatas/cat/client.xml（本机 CAT 客户端默认路径）
-->
<config mode="client">
    <servers>
        <server ip="127.0.0.1" port="2280" http-port="8088"/>
    </servers>
</config>
