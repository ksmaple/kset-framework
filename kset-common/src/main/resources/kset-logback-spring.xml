<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="application"/>
    <springProperty scope="context" name="KSET_ENV" source="spring.profiles.active" defaultValue="dev"/>
    <springProperty scope="context" name="ROOT_LEVEL" source="logging.level.root" defaultValue="INFO"/>
    <!-- 对齐 Spring Boot 标准：logging.file.path / logging.logback.rollingpolicy.* -->
    <springProperty scope="context" name="LOG_BASE" source="logging.file.path" defaultValue="tmp/logs"/>
    <springProperty scope="context" name="LOG_MAX_SIZE" source="logging.logback.rollingpolicy.max-file-size" defaultValue="100MB"/>
    <springProperty scope="context" name="LOG_MAX_HISTORY" source="logging.logback.rollingpolicy.max-history" defaultValue="7"/>

    <property name="LOG_PATH" value="${LOG_BASE}/${APP_NAME}"/>

    <!-- dev：可读文本，仅控制台 -->
    <appender name="KSET_TEXT_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId:-}] %-5level %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <springProfile name="prod,test">
        <include resource="kset-logback-file-appenders.xml"/>

        <root level="${ROOT_LEVEL}">
            <appender-ref ref="KSET_INFO_FILE"/>
            <appender-ref ref="KSET_WARN_FILE"/>
            <appender-ref ref="KSET_ERROR_FILE"/>
        </root>
    </springProfile>

    <springProfile name="dev,default">
        <logger name="com.kset" level="DEBUG"/>
        <root level="${ROOT_LEVEL}">
            <appender-ref ref="KSET_TEXT_CONSOLE"/>
        </root>
    </springProfile>
</configuration>
